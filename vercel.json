{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/STServoSDK.js",
      "dest": "/STServoSDK.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/web-serial-demo.html",
      "dest": "/web-serial-demo.html"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard.html"
    }
  ]
}
