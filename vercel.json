{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/app.py"
    },
    {
      "src": "/STServoSDK.js",
      "dest": "/STServoSDK.js"
    },
    {
      "src": "/web-serial-demo.html",
      "dest": "/web-serial-demo.html"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard.html"
    }
  ]
}
